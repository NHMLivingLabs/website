# Normalize text files and enforce LF (Unix) endings
* text=auto

# Explicitly enforce LF for common text file types
*.md     text eol=lf
*.qmd    text eol=lf
*.markdown text eol=lf
*.py     text eol=lf
*.js     text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.txt    text eol=lf
*.csv    text eol=lf
*.xml    text eol=lf
*.rmd    text eol=lf
*.R      text eol=lf
*.sh     text eol=lf
*.ps1    text eol=lf
*.psm1   text eol=lf
*.tex    text eol=lf

# Generated site output - treat as text but keep LF to stay consistent
docs/**  text eol=lf

# Binary files
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.webp   binary
*.ico    binary
*.woff   binary
*.woff2  binary
*.eot    binary
*.ttf    binary
*.otf    binary
