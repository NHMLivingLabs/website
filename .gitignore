/.quarto/

# Local environment secrets
.env

# Cache for fetched/exported data
/cache/

# Ignore generated LaTeX intermediate files produced by scripts/render_articles_to_pdf.py
# Keep the final .pdf files tracked; ignore .tex and common aux files under docs/assets/pdfs
/docs/assets/pdfs/*.tex
/docs/assets/pdfs/*.aux
/docs/assets/pdfs/*.log
/docs/assets/pdfs/*.out
/docs/assets/pdfs/*.toc

# Generic fallback: ignore tex intermediates anywhere in docs assets pdf folders
docs/**/pdfs/*.tex
docs/**/pdfs/*.aux
docs/**/pdfs/*.log
docs/**/pdfs/*.out
docs/**/pdfs/*.toc

# Ignore compiled python files and caches
__pycache__/
*.pyc

# Ignore PDF backups created by sanitiser when run with --inplace
# e.g. docs/assets/pdfs/1_Published_Protocol_2025_Tree-Tagging.pdf.bak
*.pdf.bak
docs/**/pdfs/*.pdf.bak
